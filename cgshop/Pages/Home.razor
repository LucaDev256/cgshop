@page "/"
@inject HttpClient Http

<PageTitle>Catalogue</PageTitle>



<MudGrid Style="padding: 3em;">

    @foreach (var f in products)
    {
        <MudItem sm="12" md="4">
            <cgshop.Components.Product Prod="f"></cgshop.Components.Product>
        </MudItem>

    }


</MudGrid>

@code {
    public List<Models.Product> products = new();
    public readonly string BrandPath = "media/branding.png";

    protected override async Task OnInitializedAsync()
    {
        products = await Http.GetFromJsonAsync<List<Models.Product>>("data/products.json") ?? new();
    }

}